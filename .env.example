# GlobalBiz — environment variables
#
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored — never commit your real keys.
#
# Local dev MUST use the EXPO_PUBLIC_ prefix (Metro only inlines those).
# On Netlify, either prefix works — netlify.toml maps SUPABASE_URL →
# EXPO_PUBLIC_SUPABASE_URL automatically at build time.
#
# See SUPABASE_SETUP.md for where to find these.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
